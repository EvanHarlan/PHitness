# MongoDB connection string
MONGO_URI=mongodb+srv://username:password@phitnesscluster.f3qur.mongodb.net/?retryWrites=true&w=majority&appName=PHitnessCluster

# Server configuration
PORT=5000

# Redis configuration
UPSTASH_REDIS_URL=your_redis_url

# Authentication (Custom tokens)
ACCESS_TOKEN_SECRET=your_access_token_secret  # 15m expiry
REFRESH_TOKEN_SECRET=your_refresh_token_secret  # 7d expiry

# OpenAI configuration
OPENAI_API_KEY=your_openai_api_key 